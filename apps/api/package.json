{
  "name": "@8fold/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "start": "next start -p 3003",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "node scripts/run-vitest.mjs",
    "audit:finance": "DOTENV_CONFIG_PATH=.env.local pnpm exec tsx -r dotenv/config src/payouts/auditFinanceCi.ts",
    "db:verify": "tsx scripts/verifyDbSchema.ts",
    "verify:prod-schema": "DOTENV_CONFIG_PATH=.env.local tsx scripts/verify-prod-schema.ts",
    "validate:jobs-schema": "tsx scripts/validate_jobs_schema.ts",
    "verify:prod-gate": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/verify-prod-gate.ts",
    "remove-mock-actors": "tsx scripts/remove-mock-actors.ts",
    "financial-db-introspect": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/financial-db-introspect.ts",
    "verify-financial-schema": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/verify-financial-schema.ts",
    "financial-audit": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/financial-audit.ts",
    "test:lifecycle": "tsx scripts/betaLifecycleTest.ts",
    "test:lifecycle:probe": "tsx scripts/betaLifecycleTest.ts --probe",
    "test:lifecycle:financial": "tsx scripts/financialLifecycleTest.ts",
    "test:lifecycle:financial:prod": "API_ORIGIN=https://api.8fold.app tsx scripts/financialLifecycleTest.ts",
    "stripe:cli-context": "tsx scripts/stripe-cli-context.ts",
    "verify:webhook:live": "DOTENV_CONFIG_PATH=.env.local tsx scripts/verifyStripeWebhookLive.ts",
    "stripe:env-doctor": "tsx scripts/stripeEnvDoctor.ts",
    "escrow:refund-stale-unassigned": "tsx scripts/refund-stale-unassigned.ts",
    "ci:smoke": "tsx scripts/ci-smoke.ts",
    "backfill:roles": "tsx scripts/backfill-role-taxonomy.ts",
    "migrate:router-rewards": "tsx scripts/migrate-router-rewards.ts",
    "check:prod": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/productionDbCheck.ts",
    "seed:prod": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/seedProductionTestJob.ts",
    "audit:prod-auth-db": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/productionAuthDbAudit.ts",
    "schema:hygiene": "DOTENV_CONFIG_PATH=.env.local tsx scripts/schema-hygiene-scan.ts",
    "hygiene:phaseA": "DOTENV_CONFIG_PATH=.env.local tsx scripts/run-hygiene-phaseA-migration.ts",
    "hygiene:phaseA:check": "DOTENV_CONFIG_PATH=.env.local tsx scripts/hygienePhaseACheck.ts",
    "hygiene:guard": "DOTENV_CONFIG_PATH=.env.local pnpm validate:jobs-schema && DOTENV_CONFIG_PATH=.env.local pnpm hygiene:phaseA:check",
    "predeploy": "pnpm hygiene:guard",
    "smoke:test": "tsx scripts/runtimeSmokeTest.ts",
    "smoke:admin-tier-lockdown": "tsx scripts/smoke-admin-tier-lockdown.ts",
    "admin:v4:backfill": "tsx scripts/backfill-admin-v4-domain.ts",
    "admin:v4:sync": "tsx scripts/sync-admin-v4-domain.ts",
    "seed:initial-admin": "tsx scripts/seed-initial-admin.ts"
  },
  "dependencies": {
    "@8fold/shared": "workspace:*",
    "@clerk/nextjs": "^6.37.4",
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/blob": "^2.3.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.1",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.1.6",
    "nodemailer": "^8.0.1",
    "openai": "^6.18.0",
    "pg": "^8.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^17.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.1",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
