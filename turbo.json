{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "API_ORIGIN",
    "ADMIN_ORIGIN",
    "BLOB_READ_WRITE_TOKEN",
    "CLERK_SECRET_KEY",
    "CLERK_ISSUER",
    "DATABASE_URL",
    "FIN_ADMIN_ID",
    "POOL_MAX",
    "ADMIN_CREATION_TOKEN",
    "ADMIN_JWT_SECRET",
    "LGS_AUTH_PASSWORD",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY",
    "NEXT_PUBLIC_WEB_ORIGIN",
    "WEB_ORIGIN",
    "NOMINATIM_USER_AGENT",
    "OPEN_AI_API_KEY",
    "OPENAI_API_KEY",
    "OPENAI_MESSAGE_MODEL",
    "OPENAI_MESSAGE_TEMPERATURE",
    "OPENAI_MESSAGE_MAX_TOKENS",
    "INTERNAL_DEBUG_SECRET",
    "STRIPE_MODE",
    "STRIPE_SECRET_KEY",
    "STRIPE_PUBLISHABLE_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_CONNECT_WEBHOOK_SECRET",
    "STRIPE_INTEGRITY_READ_KEY",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "TURNSTILE_SECRET_KEY",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASS",
    "SMTP_FROM",
    "WEB_APP_URL",
    "API_APP_URL",
    "GA4_PROPERTY_ID",
    "GOOGLE_INDEXING_CLIENT_EMAIL",
    "GOOGLE_INDEXING_PRIVATE_KEY",
    "NEXT_PUBLIC_GA4_MEASUREMENT_ID",
    "NEXT_PUBLIC_META_PIXEL_ID"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "API_ORIGIN",
        "ADMIN_ORIGIN",
        "BLOB_READ_WRITE_TOKEN",
        "CLERK_SECRET_KEY",
        "CLERK_ISSUER",
        "DATABASE_URL",
        "FIN_ADMIN_ID",
        "POOL_MAX",
        "ADMIN_CREATION_TOKEN",
        "ADMIN_JWT_SECRET",
        "LGS_AUTH_PASSWORD",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY",
        "NEXT_PUBLIC_WEB_ORIGIN",
        "WEB_ORIGIN",
        "NOMINATIM_USER_AGENT",
        "OPEN_AI_API_KEY",
        "OPENAI_API_KEY",
        "OPENAI_MESSAGE_MODEL",
        "OPENAI_MESSAGE_TEMPERATURE",
        "OPENAI_MESSAGE_MAX_TOKENS",
        "INTERNAL_DEBUG_SECRET",
        "STRIPE_MODE",
        "STRIPE_SECRET_KEY",
        "STRIPE_PUBLISHABLE_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_CONNECT_WEBHOOK_SECRET",
        "STRIPE_INTEGRITY_READ_KEY",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "TURNSTILE_SECRET_KEY",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_USER",
        "SMTP_PASS",
        "SMTP_FROM",
        "WEB_APP_URL",
        "API_APP_URL",
        "GA4_PROPERTY_ID",
        "GOOGLE_INDEXING_CLIENT_EMAIL",
        "GOOGLE_INDEXING_PRIVATE_KEY",
        "NEXT_PUBLIC_GA4_MEASUREMENT_ID",
        "NEXT_PUBLIC_META_PIXEL_ID"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
